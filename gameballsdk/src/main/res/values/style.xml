<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Transparent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:fontFamily">@font/font_family_poppins</item>
    </style>

    <!-- Widget-only theme. Inherits Theme.Transparent and adds dark status-bar
         icons so they stay visible over the widget's white top band. Kept separate
         so LargeNotificationActivity (also on Theme.Transparent) is unaffected. -->
    <style name="Theme.GameballWidget" parent="Theme.Transparent">
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="GameballTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:fontFamily">@font/font_family_montserrat</item>
    </style>

    <style name="text_title_style">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>